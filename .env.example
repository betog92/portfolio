# Web3Forms access key for the contact form.
# Get yours (free) at https://web3forms.com using your destination email.
# For local dev, copy this file to .env.local and fill in the value.
# For production (GitHub Pages), set it as the "WEB3FORMS_ACCESS_KEY" Actions secret.
VITE_WEB3FORMS_ACCESS_KEY=your-access-key-here
